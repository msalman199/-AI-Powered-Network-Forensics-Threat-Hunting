cat > scripts/performance_report.py << 'EOF'
#!/usr/bin/env python3
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
from model_trainer import ObfuscationDetector
from pcap_analyzer import PCAPAnalyzer
import time
import os

def generate_performance_report():
    """Generate comprehensive performance report"""
    
    # Load model
    detector = ObfuscationDetector()
    detector.load_model("models/obfuscation_detector.pkl")
    
    # Test files
    test_files = [
        ("data/normal_traffic.pcap", "Normal Traffic"),
        ("data/obfuscated_traffic.pcap", "Obfuscated Traffic"),
        ("data/mixed_traffic.pcap", "Mixed Traffic"),
        ("data/advanced_obfuscation.pcap", "Advanced Obfuscation"),
        ("data/evasion_attempts.pcap", "Evasion Attempts")
    ]
    
    results = []
    processing_times = []
    
    print("Generating Performance Report...")
    print("=" * 50)
    
    for pcap_file, description in test_files:
        if not os.path.exists(pcap_file):
            print(f"Skipping {pcap_file} (file not found)")
            continue
            
        print(f"Processing {description}...")
        
        # Measure processing time
        start_time = time.time()
        
        # Analyze PCAP
        analyzer = PCAPAnalyzer(pcap_file)
        df_features = analyzer.extract_features()
        
        if len(df_features) == 0:
            continue
        
        # Make predictions
        X = df_features[detector.feature_columns].fillna(0)
        predictions, probabilities = detector.predict(X)
        
        end_time = time.time()
        processing_time = end_time - start_time
        processing_times.append(processing_time)
        
        # Calculate metrics
        total_packets = len(df_features)
        obfuscated_count = sum(predictions)
        avg_entropy = df_features['entropy'].mean()
        max_entropy = df_features['entropy'].max()
        avg_confidence = probabilities[:, 1].mean()
        
        result = {
            'Dataset': description,
            'Total_Packets': total_packets,
            'Obfuscated_Detected': obfuscated_count,
            'Detection_Rate_%': (obfuscated_count / total_packets) * 100,
            'Avg_Entropy': avg_entropy,
            'Max_Entropy': max_entropy,
            'Avg_Confidence': avg_confidence,
            'Processing_Time_s': processing_time,
            'Packets_per_Second': total_packets / processing_time if processing_time > 0 else 0
        }
        
        results.append(result)
    
    # Create results DataFrame
    df_results = pd.DataFrame(results)
    
    # Save results
    df_results.to_csv("results/performance_report.csv", index=False)
    
    # Display summary
    print("\nPerformance Summary:")
    print(df_results.to_string(index=False, float_format='%.2f'))
    
    # Create visualizations
    create_performance_plots(df_results)
    
    return df_results

def create_performance_plots(df_results):
    """Create performance visualization plots"""
    
    # Set up the plotting style
    plt.style.use('default')
    fig, axes = plt.subplots(2, 2, figsize=(15, 12))
    
    # Plot 1: Detection Rate by Dataset
    axes[0, 0].bar(df_results['Dataset'], df_results['Detection_Rate_%'], 
                   color=['green', 'red', 'orange', 'purple', 'brown'])
    axes[0, 0].set_title('Detection Rate by Dataset')
    axes[0, 0].set_ylabel('Detection Rate (%)')
    axes[0, 0].tick_params(axis='x', rotation=45)
    
    # Plot 2: Processing Performance
    axes[0, 1].bar(df_results['Dataset'], df_results['Packets_per_Second'], 
                   color='skyblue')
    axes[0, 1].set_title('Processing Performance')
    axes[0, 1].set_ylabel('Packets per Second')
    axes[0, 1].tick_params(axis='x', rotation=45)
    
    # Plot 3: Entropy Distribution
    axes[1, 0].bar(df_results['Dataset'], df_results['Avg_Entropy'], 
                   color='lightcoral', alpha=0.7, label='Average')
    axes[1, 0].bar(df_results['Dataset'], df_results['Max_Entropy'], 
                   color='darkred', alpha=0.7, label='Maximum')
    axes[1, 0].set_title('Entropy Analysis')
    axes[1, 0].set_ylabel('Entropy Value')
    axes[1, 0].legend()
    axes[1, 0].tick_params(axis='x', rotation=45)
    
    # Plot 4: Confidence Levels
    axes[1, 1].bar(df_results['Dataset'], df_results['Avg_Confidence'], 
                   color='gold')
    axes[1, 1].set_title('Average Confidence Levels')
    axes[1, 1].set_ylabel('Confidence Score')
    axes[1, 1].tick_params(axis='x', rotation=45)
    
    plt.tight_layout()
    plt.savefig('results/performance_analysis.png', dpi=300, bbox_inches='tight')
    plt.close()
    
    print("\nPerformance plots saved to results/performance_analysis.png")

# Generate the report
if __name__ == "__main__":
    performance_data = generate_performance_report()
    
    print("\n" + "="*50)
    print("FINAL PERFORMANCE SUMMARY")
    print("="*50)
    
    total_packets = performance_data['Total_Packets'].sum()
    avg_processing_speed = performance_data['Packets_per_Second'].mean()
    
    print(f"Total packets processed: {total_packets}")
    print(f"Average processing speed: {avg_processing_speed:.2f} packets/second")
    print(f"Model successfully detected obfuscated payloads across {len(performance_data)} test datasets")
    print("\nAll results saved to results/ directory")
EOF

