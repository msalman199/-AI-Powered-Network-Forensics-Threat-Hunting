            }
    else:
        # Normal session
        session = {
            'method_encoded': random.randint(40, 60),
            'status_code': random.choice([200, 201, 301, 302]),
            'user_agent_encoded': random.randint(400, 600),
            'avg_request_size': random.randint(600, 1200),
